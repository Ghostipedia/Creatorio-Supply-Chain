	file.0000000000000001.title: "Creatorio"
	quest.0205D771F2295CC9.quest_desc: [
		"One of the Automation Challenges Presented in this pack is to automate redstone fully."
		""
		""
		"This is a small optional goal. But required to 100% the QB"
		""
		""
		"There are no strict requirements for 'completeing' this quest beyond redstone needs to be automatically produced without player input."
		"If you accomplished that, feel free to check this quest off."
	]
	quest.0205D771F2295CC9.quest_subtitle: "Automation Challenge : Automate Redstone"
	quest.02340E118E72726F.quest_desc: ["Apparently this allows packagers to work at a much faster pace for the cost of SU"]
	quest.02340E118E72726F.quest_subtitle: "Zippy Packages"
	quest.02B742F686F88CCF.quest_desc: [
		"Oh hey, dying your flour violent neon green makes it resemble enough of a slimeball you don't question it."
		""
		"You can get lime dye several ways, the easiest way is to dive into an ocean and get some sea pickels. "
		""
		""
		"You can also check EMI for more options on getting green and white dyes!"
	]
	quest.02B742F686F88CCF.quest_subtitle: "Green Enough"
	quest.064314D458FC80F7.title: "Contraptions"
	quest.0A291D506EC39422.quest_subtitle: "Capture a Blaze"
	quest.0F33047A2923634C.quest_desc: ["The Wrench is a tool which allows you to instantly break items without dropping them on the ground. Just shift-right click with the wrench and the item will be deconstructed into your inventory."]
	quest.0F33047A2923634C.quest_subtitle: "A quick reminder"
	quest.0F33047A2923634C.title: "If you haven't, Make a Wrench"
	quest.12BB6D9B9BDA5118.quest_desc: [
		"This is currently the highest level of implemented content in the Modpack"
		""
		""
		"Brass technology will appear next update."
		""
		"Focus on setting up your base to handle the crazy automation to come, as the gloves are coming off soon and you will be expected to automate nested recipes with increasing complexity."
		""
		""
		"Thanks for Trying out Create : Supply Chain!"
	]
	quest.12BB6D9B9BDA5118.quest_subtitle: "The Start of Proper Automation"
	quest.1351BA0E601248E9.quest_subtitle: "The place you spawned in."
